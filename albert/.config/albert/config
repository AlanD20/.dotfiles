[General]
frontend=widgetsboxmodel
fuzzy=true
hotkey=Ctrl+Shift+Space
notifiedUnsupportedHotkey=true
showTray=true
telemetry=false
terminal=Alacritty

[albert]
global_handler_enabled=true
trigger=alb

[application]
enabled=true

[applications]
enabled=true
fuzzy=true
global_handler_enabled=true
trigger=files
use_exec=true
use_generic_name=true
use_keywords=true

[arch_wiki]
enabled=true

[aur]
enabled=true

[calculator_muparser]
enabled=true
global_handler_enabled=true
trigger_handler_enabled=false

[calculator_qalculate]
angle_unit=2
enabled=true
global_handler_enabled=true

[chromium]
bookmarks_path=$HOME/.config/google-chrome/Default/Bookmarks
enabled=false
global_handler_enabled=true

[clipboard]
enabled=true

[datetime]
enabled=true
global_handler_enabled=true

[docker]
enabled=true
global_handler_enabled=true

[emoji]
enabled=false

[files]
enabled=true
global_handler_enabled=true
paths=/usr/local/bin
trigger="files "
usr\local\bin\followSymlinks=true
usr\local\bin\indexhidden=true
usr\local\bin\maxDepth=255
usr\local\bin\mimeFilters=application/x-executable, application/vnd.ms-excel.sheet.binary.macroEnabled.12, inode/directory, audio/*, video/*, image/*
usr\local\bin\nameFilters=@Invalid()
usr\local\bin\scanInterval=5
usr\local\bin\useFileSystemWatches=false

[hash]
enabled=true
global_handler_enabled=true

[kill]
enabled=true

[locate]
enabled=false

[pacman]
enabled=false

[pass]
enabled=false

[python]
enabled=false
watchSources=false

[qmlboxmodel]
windowPosition=@Point(610 469)

[ssh]
enabled=true
global_handler_enabled=true

[system]
enabled=true
global_handler_enabled=true
trigger="sys "

[terminal]
enabled=true

[timer]
enabled=true

[unit_converter]
enabled=true

[urlhandler]
enabled=true
global_handler_enabled=true
trigger=url

[websearch]
enabled=true
fallback_handler_enabled=true
global_handler_enabled=true
trigger="search "

[widgetsboxmodel]
action_item_padding=6
action_item_selection_border_radius=11
action_item_selection_border_width=0
alwaysOnTop=true
clearOnHide=true
clientShadow=true
darkTheme=Nord
disable_input_method=true
displayIcons=true
displayScrollbar=false
followCursor=true
hideOnFocusLoss=true
historySearch=true
input_border_radius=11
input_font_size=19
input_padding=5
itemCount=6
lightTheme=Nord
quitOnClose=false
result_item_horizontal_spacing=6
result_item_icon_size=39
result_item_padding=6
result_item_selection_border_radius=11
result_item_selection_border_width=0
result_item_subtext_font_size=9
result_item_text_font_size=14
result_item_vertical_spacing=2
showCentered=true
showFallbacksOnEmpty=true
systemShadow=true
theme=Spotlight Dark
trigger_handler_enabled=true
windowPosition=@Point(608 466)
window_border_radius=18
window_border_width=1
window_padding=7
window_shadow_offset=8
window_shadow_size=80
window_spacing=7
window_width=640

[youtube]
enabled=true
